# Production environment for VPS (.env on the server)
# Copy to your VPS deploy directory: cp .env.production.example .env

NODE_ENV=production
PORT=3000
API_PREFIX=/api/v1
APP_NAME=express-template

# Security — generate strong random secrets
JWT_SECRET=replace-with-at-least-32-char-random-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace-with-another-32-char-random-secret
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12
CORS_ORIGINS=https://yourdomain.com
TRUST_PROXY=1

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

CSRF_ENABLED=false
CSRF_SECRET=replace-with-csrf-secret-if-enabled

# Database passwords (used by docker-compose.prod.yml)
POSTGRES_PASSWORD=replace-with-strong-postgres-password

# MongoDB / Redis (internal Docker network — do not expose ports publicly)
MONGODB_ENABLED=true
REDIS_ENABLED=true
QUEUE_WORKERS_ENABLED=true
QUEUE_PREFIX=express-template

DOCS_ENABLED=false
LOG_LEVEL=info
LOG_PRETTY=false

TOKEN_CLEANUP_INTERVAL_MS=86400000
TOKEN_CLEANUP_REVOKED_RETENTION_DAYS=30
