# Application
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
APP_NAME=express-template

# Security
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
TRUST_PROXY=1

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# CSRF (enable when using cookie-based sessions)
CSRF_ENABLED=false
CSRF_SECRET=change-me-csrf-secret

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/express_template?schema=public

# Admin seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPass123
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Admin

# MongoDB
MONGODB_URI=mongodb://localhost:27017/express_template
MONGODB_ENABLED=true

# Redis + BullMQ
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380
REDIS_ENABLED=true
QUEUE_PREFIX=express-template
QUEUE_WORKERS_ENABLED=true

# API docs (defaults to enabled in development, disabled in production)
DOCS_ENABLED=true

# Refresh token cleanup
TOKEN_CLEANUP_INTERVAL_MS=86400000
TOKEN_CLEANUP_REVOKED_RETENTION_DAYS=30

# Logging
LOG_LEVEL=info
LOG_PRETTY=true
